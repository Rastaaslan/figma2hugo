{% macro render_attributes(attributes) -%}
{%- for name, value in attributes.items() %} {{ name | e }}="{{ value | e }}"{%- endfor -%}
{%- endmacro %}
{% macro render_text(text) -%}
<{{ text.tag | e }}{% if text.dom_id %} id="{{ text.dom_id | e }}"{% endif %}{% if text.id and text.dom_id and text.id != text.dom_id %} data-node-id="{{ text.id | e }}"{% endif %} class="content-text {{ text.class_name | e }}"{{ render_attributes(text.attributes) }}>
  {%- if text.segments -%}
    {%- for segment in text.segments -%}
    <span class="{{ segment.class_name | e }}"{% if segment.style %} style="{{ segment.style | e }}"{% endif %}>{{ segment.html | safe }}</span>
    {%- endfor -%}
  {%- else -%}
    {{ text.html | safe }}
  {%- endif -%}
</{{ text.tag | e }}>
{%- endmacro %}
{% macro render_asset(asset) -%}
{%- if asset.render is not sameas false -%}
{%- set asset_classes -%}content-asset {{ asset.class_name | e }}{% if asset.purpose == "background" %} bg{% endif %}{% if asset.aria_hidden %} is-decorative{% endif %}{%- endset -%}
{%- set wrapper_tag = "figure" -%}
{%- if asset.purpose == "background" or asset.aria_hidden -%}
  {%- set wrapper_tag = "div" -%}
{%- endif -%}
{%- set wrapper_attributes = dict() -%}
{%- if asset.aria_hidden -%}
  {%- set _ = wrapper_attributes.update({"aria-hidden": "true", "role": "presentation"}) -%}
{%- endif -%}
{%- if asset.purpose == "background" and asset.render_mode != "shape" and asset.format != "shape" -%}
  {%- set _ = wrapper_attributes.update({"style": "background-image: url('" ~ asset.public_path ~ "');"}) -%}
{%- endif -%}
<{{ wrapper_tag }}{% if asset.dom_id %} id="{{ asset.dom_id | e }}"{% endif %}{% if asset.id and asset.dom_id and asset.id != asset.dom_id %} data-node-id="{{ asset.id | e }}"{% endif %} class="{{ asset_classes }}" data-purpose="{{ asset.purpose | e }}"{% if asset.render_mode %} data-render-mode="{{ asset.render_mode | e }}"{% endif %}{{ render_attributes(wrapper_attributes) }}>
  {%- if asset.purpose != "background" and asset.render_mode != "shape" and asset.format != "shape" -%}
  <img src="{{ asset.public_path | e }}" alt="{{ asset.alt | e }}"{% if asset.aria_hidden %} aria-hidden="true"{% endif %}{% if asset.width %} width="{{ asset.width | e }}"{% endif %}{% if asset.height %} height="{{ asset.height | e }}"{% endif %}{{ render_attributes(asset.attributes) }}>
  {%- endif -%}
</{{ wrapper_tag }}>
{%- endif -%}
{%- endmacro %}
{% macro render_form_control(control) -%}
{%- set attrs = dict(control.attributes) -%}
{%- set _ = attrs.update({"id": control.id, "class": "content-form-control " ~ control.class_name}) -%}
{%- if control.style -%}
  {%- set _ = attrs.update({"style": control.style}) -%}
{%- endif -%}
{%- if control.tag == "textarea" and control.rows -%}
  {%- set _ = attrs.update({"rows": control.rows}) -%}
{%- endif -%}
{%- if control.tag == "textarea" -%}
<textarea{{ render_attributes(attrs) }}>{{ control.value | e }}</textarea>
{%- elif control.tag == "select" -%}
<select{{ render_attributes(attrs) }}>{%- for option in control.options -%}<option value="{{ option.value | e }}"{% if option.selected %} selected="selected"{% endif %}>{{ option.label | e }}</option>{%- endfor -%}</select>
{%- else -%}
<input{{ render_attributes(attrs) }}>
{%- endif -%}
{%- endmacro %}
{% macro render_node(node) -%}
  {%- if node.kind == "text" -%}
    {{ render_text(node.text) }}
  {%- elif node.kind == "asset" -%}
    {{ render_asset(node.asset) }}
  {%- elif node.role == "field" and node.form_control -%}
<{{ node.tag | e }}{% if node.dom_id %} id="{{ node.dom_id | e }}"{% endif %}{% if node.id and node.dom_id and node.id != node.dom_id %} data-node-id="{{ node.id | e }}"{% endif %} class="content-node {{ node.class_name | e }}"{{ render_attributes(node.attributes) }}>
      {%- for child in node.children -%}
        {{ render_node(child) }}
      {%- endfor -%}
      {{ render_form_control(node.form_control) }}
</{{ node.tag | e }}>
  {%- else -%}
<{{ node.tag | e }}{% if node.dom_id %} id="{{ node.dom_id | e }}"{% endif %}{% if node.id and node.dom_id and node.id != node.dom_id %} data-node-id="{{ node.id | e }}"{% endif %} class="content-node {{ node.class_name | e }}"{{ render_attributes(node.attributes) }}>
    {%- if node.role == "accordion-item" -%}
      {%- for child in node.children if child.role == "accordion-trigger" -%}
        {{ render_node(child) }}
      {%- endfor -%}
      {%- for child in node.children if child.role == "accordion-panel" -%}
        {{ render_node(child) }}
      {%- endfor -%}
      {%- for child in node.children if child.role != "accordion-trigger" and child.role != "accordion-panel" -%}
        {{ render_node(child) }}
      {%- endfor -%}
    {%- else -%}
      {%- for child in node.children -%}
        {{ render_node(child) }}
      {%- endfor -%}
    {%- endif -%}
</{{ node.tag | e }}>
  {%- endif -%}
{%- endmacro %}
{% macro render_section(section) -%}
<{{ section.tag | e }} id="{{ section.anchor | e }}" class="page-section {{ section.class_name | e }}"{{ render_attributes(section.attributes | default({})) }}>
  <div class="page-section__inner">
    {%- for node in section.children -%}
      {{ render_node(node) }}
    {%- endfor -%}
  </div>
</{{ section.tag | e }}>
{%- endmacro %}
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ page.title | e }}</title>
    <link rel="stylesheet" href="styles.css">
    <script src="accordion.js" defer></script>
  </head>
  <body
    class="page page--{{ page.slug | e }}"
    data-page-shell="{{ page.shell_mode | default('fixed') | e }}"
    data-page-layout-strategy="{{ page.layout.inferred_strategy | default('absolute') | e }}"
    data-page-flow="{{ 'true' if page.layout.inferred_flow else 'false' }}"
  >
    {% for section in header_sections %}
      {{ render_section(section) }}
    {% endfor %}
    <main class="page-main">
      {% for section in body_sections %}
        {{ render_section(section) }}
      {% endfor %}
    </main>
    {% for section in footer_sections %}
      {{ render_section(section) }}
    {% endfor %}
  </body>
</html>
